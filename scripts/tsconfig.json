{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "../dist/scripts",
    "rootDir": ".",
    "baseUrl": ".",
    "types": ["node"],
    "allowJs": true,
    "declaration": true,
    "sourceMap": true,
    "declarationMap": true,
    "composite": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules", "dist"]
} 