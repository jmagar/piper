# Paths to watch (comma-separated)
WATCH_PATHS=./src,./packages

# File patterns to watch (comma-separated)
WATCH_FILES=package.json,.eslintrc.*,eslint.config.*,globals.css,postcss.config.*,tsconfig.json

# File extension watcher configuration
ENABLE_EXTENSION_WATCHER=true
DUPLICATE_WARNING_MESSAGE=Potential duplicate file detected

# Specific file watcher configuration
ENABLE_FILE_WATCHER=true

# Embeddings configuration (enabled by default)
ENABLE_EMBEDDINGS=true
EMBEDDING_INTERVAL_MINUTES=5
GENERATE_DIRECTORY_TREE=true

# Qdrant configuration
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=code-embeddings

# Embedding model configuration
USE_LOCAL_EMBEDDINGS=true
LOCAL_MODEL=Xenova/all-MiniLM-L6-v2
OPENAI_API_KEY=your-openai-api-key

# Linting configuration
LINT_COMMAND=pnpm lint

# Notification configuration
USE_NOTIFICATIONS=false
GOTIFY_URL=https://your-gotify-server.com
GOTIFY_TOKEN=your-gotify-app-token

# Files to ignore (comma-separated patterns)
IGNORE_PATTERNS=.git,node_modules,dist,build,.next,*.min.js,*.map,.cache,.mypy_cache,.cursor,.tasks,.vscode,*.mp4,*.jpg,*.png

# Performance settings
MAX_FILE_SIZE_KB=1024
BATCH_SIZE=100

# Output settings
LOG_LEVEL=info # debug, info, warn, error
COLORIZE_OUTPUT=true