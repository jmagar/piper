{
  "name": "code-watcher",
  "version": "1.0.0",
  "description": "Tool to monitor file duplicates with different extensions and generate code embeddings",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node --esm src/index.ts",
    "watch": "nodemon --watch src --ext ts --exec \"ts-node --esm src/index.ts\"",
    "lint": "eslint 'src/**/*.ts'",
    "clean": "rimraf dist"
  },
  "keywords": [
    "code",
    "monitor",
    "embeddings",
    "watcher",
    "duplicate",
    "ai",
    "extensions"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@qdrant/js-client-rest": "^1.7.0",
    "@xenova/transformers": "^2.14.0",
    "ascii-tree": "^0.3.0",
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "deep-equal": "^2.2.3",
    "diff": "^5.1.0",
    "dotenv": "^16.4.0",
    "file-type": "^19.0.0",
    "glob": "^10.3.10",
    "openai": "^4.28.0"
  },
  "devDependencies": {
    "@types/ascii-tree": "^0.3.4",
    "@types/chokidar": "^2.1.3",
    "@types/deep-equal": "^1.0.4",
    "@types/diff": "^5.0.9",
    "@types/node": "^20.11.0",
    "nodemon": "^3.0.3",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}