    "@langchain/langgraph": "^0.2.46",
    "@langchain/openai": "^0.4.4",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@modelcontextprotocol/server-brave-search": "^0.6.2",
    "@modelcontextprotocol/server-filesystem": "^2025.1.14",
