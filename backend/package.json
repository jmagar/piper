{
  "name": "pooper-backend",
  "version": "0.1.0",
  "description": "Pooper Backend API",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:all": "cd .. && tsx scripts/start-servers.ts",
    "test-mcp": "tsx watch src/test-mcp-server.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "terminal-server": "tsx src/terminal-server/start.ts",
    "terminal-server:dev": "tsx watch src/terminal-server/start.ts",
    "lint": "eslint --config eslint.config.mjs .",
    "lint:fix": "eslint --config eslint.config.mjs . --fix",
    "generate": "prisma generate && openapi-generator-cli generate -i ../openapi/main.yaml -g typescript-node -o src/generated --additional-properties=supportsES6=true,npmName=@api/server,platform=node,useObjectParameters=true,useSingleRequestParameter=true",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "test": "vitest",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "langgraph": "langgraph serve"
  },
  "dependencies": {
    "@h1deya/langchain-mcp-tools": "^0.1.13",
    "@langchain/anthropic": "^0.3.13",
    "@langchain/core": "^0.3.40",
    "@langchain/groq": "^0.1.3",
    "@langchain/langgraph": "^0.2.46",
    "@langchain/openai": "^0.4.4",
    "@prisma/client": "^6.4.0",
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "json5": "^2.2.3",
    "jsonwebtoken": "^9.0.2",
    "node-pty": "^1.0.0",
    "redis": "^4.7.0",
    "socket.io": "^4.8.1",
    "uuid": "^11.1.0",
    "winston": "^3.17.0",
    "ws": "^8.18.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^10.1.1",
    "@n8n/json-schema-to-zod": "1.1.0",
    "@openapitools/openapi-generator-cli": "^2.16.3",
    "@types/cors": "^2.8.17",
    "@types/debug": "^4.1.12",
    "@types/express": "^5.0.0",
    "@types/express-serve-static-core": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.13.4",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.14",
    "@typescript-eslint/eslint-plugin": "^8.24.1",
    "@typescript-eslint/parser": "^8.24.1",
    "@vitest/coverage-v8": "^3.0.6",
    "chalk": "^5.4.1",
    "debug": "^4.4.0",
    "eslint": "^9.20.1",
    "openapi-types": "^12.1.3",
    "openapi-typescript-codegen": "^0.29.0",
    "prisma": "^6.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.1",
    "vitest": "^3.0.6",
    "vitest-mock-extended": "^1.3.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@openapitools/openapi-generator-cli",
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "node-pty",
      "prisma"
    ]
  }
}
